{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",

    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "jsx": "react-jsx",

    "strict": false,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    "allowJs": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,

    "baseUrl": ".",

    "paths": {
      "@/*": ["./*"]
    },

    "types": ["node"],

    "noEmit": true
  },

  "include": [
    "src",
    "routes",
    "services",
    "utils",
    "server.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}